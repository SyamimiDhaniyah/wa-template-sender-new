{
  "name": "whatsconect",
  "version": "1.1.0",
  "description": "WhatsConect messaging console for templates, appointments, and marketing.",
  "author": "Dentabay",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis --prepackaged dist/win-unpacked --config.win.signAndEditExecutable=false --config.win.verifyUpdateCodeSignature=false --publish never",
    "stamp:win:exe": "node scripts/stamp-win-exe.mjs",
    "dist:win:icon": "electron-builder --win dir && npm run stamp:win:exe && npm run dist:win"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.dentabay.whatsconect",
    "productName": "WhatsConect",
    "afterPack": "scripts/after-pack-mac.cjs",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "data/**/*",
      "go-backend/go-backend",
      "go-backend/go-backend.exe"
    ],
    "asarUnpack": [
      "go-backend/go-backend",
      "go-backend/go-backend.exe"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "extraFiles": [
        {
          "from": "assets/WhatsConect Launcher.cmd",
          "to": "WhatsConect Launcher.cmd"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "mergeASARs": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "assets/installer.nsh"
    }
  }
}
