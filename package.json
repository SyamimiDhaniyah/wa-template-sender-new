{
  "name": "whatsconect",
  "version": "1.2.0",
  "description": "WhatsConect messaging console for templates, appointments, and marketing.",
  "author": "Dentabay",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis --prepackaged dist/win-unpacked --config.win.signAndEditExecutable=false --config.win.verifyUpdateCodeSignature=false --publish never",
    "stamp:win:exe": "node scripts/stamp-win-exe.mjs",
    "dist:win:icon": "electron-builder --win dir && npm run stamp:win:exe && npm run dist:win"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "electron-store": "^8.2.0",
    "pino": "^9.3.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.dentabay.whatsconect",
    "productName": "WhatsConect",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "data/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "extraFiles": [
      {
        "from": "assets/WhatsConect Launcher.cmd",
        "to": "WhatsConect Launcher.cmd"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "assets/installer.nsh"
    }
  }
}
